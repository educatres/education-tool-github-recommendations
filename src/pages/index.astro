---
import { educationLevels, entries } from "../lib/catalog";
import "../styles/global.css";
import logoImage from "../../logo.png";

const totalRepos = entries.length;
const logoUrl = logoImage.src;

function compactIntro(value: string) {
  const cleaned = value.replace(/\s+/g, " ").trim();
  const sentences = cleaned.match(/[^。！？.!?]+[。！？.!?]?/g) ?? [cleaned];
  return sentences.slice(0, 2).join("").trim();
}
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="為教育工作者整理的 GitHub 教育工具推薦網站，讀取 list.txt 的開源專案並整理適用教育階段、教學用途與注意事項。"
    />
    <title>教育工具 GitHub 推薦</title>
  </head>
  <body>
    <main class="shell">
      <header class="masthead">
        <div>
          <p class="eyebrow">Guide to Education and Research</p>
          <div class="titleRow">
            <img class="siteLogo" src={logoUrl} alt="" />
            <h1>教育工具推薦</h1>
          </div>
          <div class="intro">
            <p>
              在教學與研究活動中，經常會需要使用各種小工具。合適的工具雖然看似簡單，卻能減少重複操作，讓課程準備、教學互動與研究流程更順暢。因此，我整理了一些實用的教學與研究工具，希望協助老師與學生減輕操作負擔。
            </p>
            <p>
              收錄工具時，會盡量以開源專案為優先，但不以開源作為必要條件。更重要的是，希望這些工具不需註冊、不過度蒐集個人資料，也盡可能避免廣告干擾。除了整理現有工具外，我也自行開發並分享了一些小工具，希望提供免費、不索取個資、無廣告的教學資源。
            </p>
            <p>
              以下內容主要參考 GitHub 專案的 README 與公開 metadata，整理成適合教育工作者快速評估的資訊，包括適用對象、教學情境與導入時的注意事項。
            </p>
            <p>
              一個人的力量與接觸領域有限，如果您也有推薦的工具，歡迎填寫
              <a
                href="https://docs.google.com/forms/d/e/1FAIpQLScPBw_p9R56pkXTb-tcceL5hK7KqXnge62VYtQttEEsgVnIww/viewform?usp=header"
                target="_blank"
                rel="noreferrer"
              >
                推薦表單
              </a>
              ，和我們一起補充、完善這份教育工具清單，讓更多老師與學生都能受益。
            </p>
          </div>
          <nav class="levelQuickSelect" aria-label="依教育階段快速篩選">
            <span>教育階段</span>
            <div>
              <button type="button" data-level-filter="" aria-pressed="true">全部</button>
              {educationLevels.map((level) => (
                <button type="button" data-level-filter={level} aria-pressed="false">{level}</button>
              ))}
            </div>
          </nav>
        </div>
        <div class="stats" aria-label="網站統計">
          <div>
            <strong>{totalRepos}</strong>
            <span>工具</span>
          </div>
          <div>
            <strong>{educationLevels.length}</strong>
            <span>教育階段</span>
          </div>
        </div>
      </header>

      <section class="toolbar" aria-label="推薦清單控制項">
        <label class="search">
          <span>搜尋</span>
          <input id="search" type="search" placeholder="工具、用途、階段" autocomplete="off" />
        </label>
        <label>
          <span>教育階段</span>
          <select id="level">
            <option value="">全部</option>
            {educationLevels.map((level) => <option value={level}>{level}</option>)}
          </select>
        </label>
        <label>
          <span>排序</span>
          <select id="sort">
            <option value="name">名稱</option>
            <option value="updated">最近更新</option>
          </select>
        </label>
        <button class="toolbarButton" id="toggleDetails" type="button" aria-pressed="true">
          展開細節
        </button>
        <div class="favoriteTools" aria-label="收藏清單工具">
          <span id="favoriteCount" aria-live="polite">0 個收藏</span>
          <button type="button" id="favoriteOnly" aria-pressed="false">只顯示收藏</button>
          <button type="button" id="clearFavorites">清除收藏</button>
          <button type="button" id="exportFavorites">匯出收藏清單</button>
          <button type="button" id="importFavorites">匯入收藏清單</button>
          <input id="favoriteFile" type="file" accept="application/json,.json" hidden />
        </div>
      </section>

      <section class="catalog" id="catalog" aria-live="polite">
        {
          entries.length === 0 ? (
            <div class="empty">
              <h2>目前尚未收錄工具</h2>
              <p>在 list.txt 新增 GitHub repo 連結後，執行 npm run import:list 產生推薦資料。</p>
            </div>
          ) : (
            entries.map((entry) => (
              <article
                class="card is-compact"
                data-name={entry.name.toLowerCase()}
                data-favorite-id={entry.repoUrl}
                data-description={`${entry.description} ${entry.educatorSummary}`.toLowerCase()}
                data-search={`${entry.name} ${entry.description} ${entry.educatorSummary} ${entry.educationLevels.join(" ")} ${entry.useCases.join(" ")} ${entry.cautions.join(" ")} ${entry.install} ${entry.language} ${entry.authorGitHub}`.toLowerCase()}
                data-author={entry.authorName.toLowerCase()}
                data-github={entry.authorGitHub.toLowerCase()}
                data-language={entry.language}
                data-levels={entry.educationLevels.join(",")}
                data-use-cases={entry.useCases.join(" ").toLowerCase()}
                data-updated={entry.lastPushedAt || entry.submittedAt}
              >
                <div class="cardTop">
                  <div class="identity">
                    <div>
                      <h2>{entry.name}</h2>
                      <a href={`https://github.com/${entry.authorGitHub}`} target="_blank" rel="noreferrer">
                        @{entry.authorGitHub}
                      </a>
                      <p class="compactIntro">{compactIntro(entry.description)}</p>
                    </div>
                  </div>
                </div>

                <div class="cardDetails">
                  <p class="description">{entry.description}</p>
                  <p class="summary">{entry.educatorSummary}</p>

                  <div class="section">
                    <h3>適用群體</h3>
                    <div class="chips">
                      {entry.educationLevels.map((level) => <span>{level}</span>)}
                    </div>
                  </div>

                  <div class="section">
                    <h3>教學用途</h3>
                    <ul>
                      {entry.useCases.map((item) => <li>{item}</li>)}
                    </ul>
                  </div>

                  <div class="section caution">
                    <h3>導入注意</h3>
                    <ul>
                      {entry.cautions.map((item) => <li>{item}</li>)}
                    </ul>
                  </div>

                  <div class="section install">
                    <h3>啟動或安裝方式</h3>
                    <p>{entry.install}</p>
                  </div>
                </div>

                <div class="links">
                  <button
                    class="favoriteButton"
                    type="button"
                    aria-pressed="false"
                    aria-label={`將 ${entry.name} 加入收藏清單`}
                    title="加入收藏清單"
                  >
                    <span aria-hidden="true">♡</span>
                  </button>
                  <button
                    class="detailReveal"
                    type="button"
                    aria-expanded="false"
                    aria-label={`展開 ${entry.name} 的細節`}
                    title="展開細節"
                  >
                    ...
                  </button>
                  <a href={entry.repoUrl} target="_blank" rel="noreferrer">原始出處</a>
                  {entry.launchUrl ? <a href={entry.launchUrl} target="_blank" rel="noreferrer">線上使用</a> : null}
                  {entry.homepage ? <a href={entry.homepage} target="_blank" rel="noreferrer">網站</a> : null}
                </div>
              </article>
            ))
          )
        }
        <div class="noResults" id="noResults" hidden>
          <h2>沒有符合條件的工具</h2>
          <p>試著改用較短的關鍵字，或切回全部教育階段。</p>
        </div>
      </section>

      <footer class="siteFooter">
        <span>資料來源：list.txt 與 GitHub API，最近同步日期：2026-07-12</span>
      </footer>
    </main>

    <script>
      function requiredElement<T extends HTMLElement>(selector: string): T {
        const element = document.querySelector<T>(selector);
        if (!element) throw new Error(`Missing required element: ${selector}`);
        return element;
      }

      const cards = Array.from(document.querySelectorAll<HTMLElement>(".card"));
      const catalog = requiredElement<HTMLElement>("#catalog");
      const noResults = requiredElement<HTMLElement>("#noResults");
      const levelButtons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-level-filter]"));
      const controls = {
        search: requiredElement<HTMLInputElement>("#search"),
        level: requiredElement<HTMLSelectElement>("#level"),
        sort: requiredElement<HTMLSelectElement>("#sort"),
        toggleDetails: requiredElement<HTMLButtonElement>("#toggleDetails"),
        favoriteCount: requiredElement<HTMLElement>("#favoriteCount"),
        favoriteOnly: requiredElement<HTMLButtonElement>("#favoriteOnly"),
        clearFavorites: requiredElement<HTMLButtonElement>("#clearFavorites"),
        exportFavorites: requiredElement<HTMLButtonElement>("#exportFavorites"),
        importFavorites: requiredElement<HTMLButtonElement>("#importFavorites"),
        favoriteFile: requiredElement<HTMLInputElement>("#favoriteFile")
      };

      const FAVORITES_KEY = "education-tool-favorites";
      const availableFavoriteIds = new Set(cards.map((card) => data(card, "favoriteId")));
      let favorites = loadFavorites();

      function data(card: HTMLElement, key: string): string {
        return card.dataset[key] ?? "";
      }

      function loadFavorites(): Set<string> {
        try {
          const stored = JSON.parse(localStorage.getItem(FAVORITES_KEY) ?? "[]");
          if (!Array.isArray(stored)) return new Set();
          return new Set(stored.filter((id): id is string => typeof id === "string"));
        } catch {
          return new Set();
        }
      }

      function saveFavorites() {
        localStorage.setItem(FAVORITES_KEY, JSON.stringify([...favorites]));
      }

      function syncFavorites() {
        cards.forEach((card) => {
          const button = card.querySelector<HTMLButtonElement>(".favoriteButton");
          if (!button) return;
          const name = card.querySelector("h2")?.textContent?.trim() || "此工具";
          const isFavorite = favorites.has(data(card, "favoriteId"));
          button.classList.toggle("is-favorite", isFavorite);
          button.setAttribute("aria-pressed", String(isFavorite));
          button.setAttribute("aria-label", `${isFavorite ? "從" : "將"} ${name} ${isFavorite ? "移出" : "加入"}收藏清單`);
          button.title = isFavorite ? "移出收藏清單" : "加入收藏清單";
          const icon = button.querySelector("span");
          if (icon) icon.textContent = isFavorite ? "♥" : "♡";
        });
        controls.favoriteCount.textContent = `${favorites.size} 個收藏`;
        controls.clearFavorites.disabled = favorites.size === 0;
        controls.exportFavorites.disabled = favorites.size === 0;
      }

      function downloadFavorites() {
        const favoriteEntries = cards
          .filter((card) => favorites.has(data(card, "favoriteId")))
          .map((card) => ({
            name: card.querySelector("h2")?.textContent?.trim() || "",
            repoUrl: data(card, "favoriteId")
          }));
        const payload = JSON.stringify({ version: 1, favorites: favoriteEntries }, null, 2);
        const url = URL.createObjectURL(new Blob([payload], { type: "application/json" }));
        const link = document.createElement("a");
        link.href = url;
        link.download = `education-tool-favorites-${new Date().toISOString().slice(0, 10)}.json`;
        link.click();
        URL.revokeObjectURL(url);
      }

      async function importFavorites(file: File) {
        try {
          const payload = JSON.parse(await file.text());
          const items = Array.isArray(payload) ? payload : payload?.favorites;
          if (!Array.isArray(items)) throw new Error("invalid format");
          const ids = items.map((item) => typeof item === "string" ? item : item?.repoUrl);
          const imported = ids.filter((id): id is string => typeof id === "string" && availableFavoriteIds.has(id));
          favorites = new Set(imported);
          saveFavorites();
          syncFavorites();
          render();
          window.alert(`已匯入 ${favorites.size} 個收藏。`);
        } catch {
          window.alert("無法匯入：請選擇由本站匯出的有效 JSON 收藏清單。");
        } finally {
          controls.favoriteFile.value = "";
        }
      }

      function matches(card: HTMLElement) {
        const query = controls.search.value.trim().toLowerCase();
        const level = controls.level.value;
        const haystack = [
          data(card, "search"),
          data(card, "name"),
          data(card, "description"),
          data(card, "author"),
          data(card, "github"),
          data(card, "language").toLowerCase(),
          data(card, "levels"),
          data(card, "useCases")
        ].join(" ");

        return (
          (!query || haystack.includes(query)) &&
          (!level || data(card, "levels").split(",").includes(level)) &&
          (controls.favoriteOnly.getAttribute("aria-pressed") !== "true" ||
            favorites.has(data(card, "favoriteId")))
        );
      }

      function sortCards(visibleCards: HTMLElement[]) {
        const mode = controls.sort.value;
        return visibleCards.sort((a, b) => {
          if (mode === "name") return data(a, "name").localeCompare(data(b, "name"));
          if (mode === "updated") return data(b, "updated").localeCompare(data(a, "updated"));
          return data(a, "name").localeCompare(data(b, "name"));
        });
      }

      function validLevel(value: string) {
        return Array.from(controls.level.options).some((option) => option.value === value);
      }

      function levelFromUrl() {
        const params = new URLSearchParams(window.location.search);
        const value = params.get("level") ?? params.get("教育階段") ?? "";
        return validLevel(value) ? value : "";
      }

      function syncLevelButtons() {
        levelButtons.forEach((button) => {
          const isActive = (button.dataset.levelFilter ?? "") === controls.level.value;
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-pressed", String(isActive));
        });
      }

      function syncLevelUrl() {
        const url = new URL(window.location.href);
        if (controls.level.value) {
          url.searchParams.set("level", controls.level.value);
          url.searchParams.delete("教育階段");
        } else {
          url.searchParams.delete("level");
          url.searchParams.delete("教育階段");
        }
        window.history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
      }

      function render() {
        const visible = sortCards(cards.filter(matches));
        cards.forEach((card) => {
          card.hidden = !visible.includes(card);
        });
        visible.forEach((card) => catalog.appendChild(card));
        noResults.hidden = cards.length === 0 || visible.length > 0;
      }

      function syncCardExpandButton(card: HTMLElement) {
        const button = card.querySelector<HTMLButtonElement>(".detailReveal");
        if (!button) return;

        const title = card.querySelector("h2")?.textContent?.trim() || "此工具";
        const isExpanded = card.classList.contains("is-expanded");
        button.setAttribute("aria-expanded", String(isExpanded));
        button.setAttribute("aria-label", `${isExpanded ? "收合" : "展開"} ${title} 的細節`);
        button.title = isExpanded ? "收合細節" : "展開細節";
      }

      function setCompactMode(isCompact: boolean) {
        cards.forEach((card) => {
          card.classList.toggle("is-compact", isCompact);
          card.classList.remove("is-expanded");
          syncCardExpandButton(card);
        });

        controls.toggleDetails.textContent = isCompact ? "展開細節" : "隱藏細節";
        controls.toggleDetails.setAttribute("aria-pressed", String(isCompact));
      }

      controls.search.addEventListener("input", render);
      controls.level.addEventListener("change", () => {
        syncLevelButtons();
        syncLevelUrl();
        render();
      });
      controls.sort.addEventListener("change", render);
      levelButtons.forEach((button) => {
        button.addEventListener("click", () => {
          controls.level.value = button.dataset.levelFilter ?? "";
          syncLevelButtons();
          syncLevelUrl();
          render();
        });
      });
      controls.toggleDetails.addEventListener("click", () => {
        const isCompact = !cards.every((card) => card.classList.contains("is-compact"));
        setCompactMode(isCompact);
      });
      controls.favoriteOnly.addEventListener("click", () => {
        const isActive = controls.favoriteOnly.getAttribute("aria-pressed") !== "true";
        controls.favoriteOnly.setAttribute("aria-pressed", String(isActive));
        render();
      });
      controls.clearFavorites.addEventListener("click", () => {
        if (favorites.size === 0 || !window.confirm("確定要清除所有收藏嗎？")) return;
        favorites.clear();
        saveFavorites();
        syncFavorites();
        render();
      });
      controls.exportFavorites.addEventListener("click", downloadFavorites);
      controls.importFavorites.addEventListener("click", () => controls.favoriteFile.click());
      controls.favoriteFile.addEventListener("change", () => {
        const file = controls.favoriteFile.files?.[0];
        if (file) void importFavorites(file);
      });
      cards.forEach((card) => {
        card.querySelector(".favoriteButton")?.addEventListener("click", () => {
          const id = data(card, "favoriteId");
          favorites.has(id) ? favorites.delete(id) : favorites.add(id);
          saveFavorites();
          syncFavorites();
          render();
        });
        card.querySelector(".detailReveal")?.addEventListener("click", () => {
          card.classList.toggle("is-expanded");
          syncCardExpandButton(card);
        });
        syncCardExpandButton(card);
      });
      controls.level.value = levelFromUrl();
      syncLevelButtons();
      syncLevelUrl();
      setCompactMode(true);
      syncFavorites();
      render();
    </script>
  </body>
</html>
