---
import { educationLevels, entries } from "../lib/catalog";
import "../styles/global.css";

const totalStars = entries.reduce((sum, entry) => sum + entry.stars, 0);
const totalRepos = entries.length;

function compactIntro(value: string) {
  const cleaned = value.replace(/\s+/g, " ").trim();
  const sentences = cleaned.match(/[^。！？.!?]+[。！？.!?]?/g) ?? [cleaned];
  return sentences.slice(0, 2).join("").trim();
}
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="為教育工作者整理的 GitHub 教育工具推薦網站，讀取 list.txt 的開源專案並整理適用教育階段、教學用途、注意事項與 GitHub stars。"
    />
    <title>教育工具 GitHub 推薦</title>
  </head>
  <body>
    <main class="shell">
      <header class="masthead">
        <div>
          <p class="eyebrow">GitHub Education Tools</p>
          <h1>教育工具推薦</h1>
          <div class="intro">
            <p>
              在教學與研究活動中，經常會需要使用各種小工具。合適的工具雖然看似簡單，卻能減少重複操作，讓課程準備、教學互動與研究流程更順暢。因此，我整理了一些實用的教學與研究工具，希望協助老師與學生減輕操作負擔，把更多時間留給真正重要的學習與研究工作。
            </p>
            <p>
              收錄工具時，會盡量以開源專案為優先，但不以開源作為必要條件。更重要的是，希望這些工具不需註冊、不過度蒐集個人資料，也盡可能避免廣告干擾。除了整理現有工具外，我也自行開發並分享了一些小工具，希望提供免費、不索取個資、無廣告，而且真正實用的教學資源。
            </p>
            <p>
              以下內容主要參考 GitHub 專案的 README 與公開 metadata，整理成適合教育工作者快速評估的資訊，包括適用對象、教學情境、導入時的注意事項，以及 GitHub Stars 等參考指標。
            </p>
          </div>
        </div>
        <div class="stats" aria-label="網站統計">
          <div>
            <strong>{totalRepos}</strong>
            <span>工具</span>
          </div>
          <div>
            <strong>{educationLevels.length}</strong>
            <span>教育階段</span>
          </div>
          <div>
            <strong>{totalStars}</strong>
            <span>Stars</span>
          </div>
        </div>
      </header>

      <section class="toolbar" aria-label="推薦清單控制項">
        <label class="search">
          <span>搜尋</span>
          <input id="search" type="search" placeholder="工具、用途、階段" autocomplete="off" />
        </label>
        <label>
          <span>教育階段</span>
          <select id="level">
            <option value="">全部</option>
            {educationLevels.map((level) => <option value={level}>{level}</option>)}
          </select>
        </label>
        <label>
          <span>排序</span>
          <select id="sort">
            <option value="stars">Stars</option>
            <option value="name">名稱</option>
            <option value="updated">最近更新</option>
          </select>
        </label>
        <button class="toolbarButton" id="toggleDetails" type="button" aria-pressed="true">
          展開細節
        </button>
      </section>

      <section class="catalog" id="catalog" aria-live="polite">
        {
          entries.length === 0 ? (
            <div class="empty">
              <h2>目前尚未收錄工具</h2>
              <p>在 list.txt 新增 GitHub repo 連結後，執行 npm run import:list 產生推薦資料。</p>
            </div>
          ) : (
            entries.map((entry) => (
              <article
                class="card is-compact"
                data-name={entry.name.toLowerCase()}
                data-description={`${entry.description} ${entry.educatorSummary}`.toLowerCase()}
                data-search={`${entry.name} ${entry.description} ${entry.educatorSummary} ${entry.educationLevels.join(" ")} ${entry.useCases.join(" ")} ${entry.cautions.join(" ")} ${entry.install} ${entry.language} ${entry.authorGitHub}`.toLowerCase()}
                data-author={entry.authorName.toLowerCase()}
                data-github={entry.authorGitHub.toLowerCase()}
                data-language={entry.language}
                data-levels={entry.educationLevels.join(",")}
                data-use-cases={entry.useCases.join(" ").toLowerCase()}
                data-stars={entry.stars}
                data-updated={entry.lastPushedAt || entry.submittedAt}
              >
                <div class="cardTop">
                  <div class="identity">
                    <div>
                      <h2>{entry.name}</h2>
                      <a href={`https://github.com/${entry.authorGitHub}`} target="_blank" rel="noreferrer">
                        @{entry.authorGitHub}
                      </a>
                      <p class="compactIntro">{compactIntro(entry.description)}</p>
                    </div>
                  </div>
                  <div class="rating" title="GitHub Stars">
                    <span aria-hidden="true">★</span>
                    <strong>{entry.stars}</strong>
                  </div>
                </div>

                <div class="cardDetails">
                  <p class="description">{entry.description}</p>
                  <p class="summary">{entry.educatorSummary}</p>

                  <div class="section">
                    <h3>適用群體</h3>
                    <div class="chips">
                      {entry.educationLevels.map((level) => <span>{level}</span>)}
                    </div>
                  </div>

                  <div class="section">
                    <h3>教學用途</h3>
                    <ul>
                      {entry.useCases.map((item) => <li>{item}</li>)}
                    </ul>
                  </div>

                  <div class="section caution">
                    <h3>導入注意</h3>
                    <ul>
                      {entry.cautions.map((item) => <li>{item}</li>)}
                    </ul>
                  </div>

                  <div class="section install">
                    <h3>啟動或安裝方式</h3>
                    <p>{entry.install}</p>
                  </div>
                </div>

                <div class="links">
                  <button
                    class="detailReveal"
                    type="button"
                    aria-expanded="false"
                    aria-label={`展開 ${entry.name} 的細節`}
                    title="展開細節"
                  >
                    ...
                  </button>
                  <a href={entry.repoUrl} target="_blank" rel="noreferrer">原始出處</a>
                  {entry.launchUrl ? <a href={entry.launchUrl} target="_blank" rel="noreferrer">線上使用</a> : null}
                  {entry.homepage ? <a href={entry.homepage} target="_blank" rel="noreferrer">網站</a> : null}
                </div>
              </article>
            ))
          )
        }
        <div class="noResults" id="noResults" hidden>
          <h2>沒有符合條件的工具</h2>
          <p>試著改用較短的關鍵字，或切回全部教育階段。</p>
        </div>
      </section>

      <footer class="siteFooter">
        <span>資料來源：list.txt 與 GitHub API</span>
      </footer>
    </main>

    <script>
      function requiredElement<T extends HTMLElement>(selector: string): T {
        const element = document.querySelector<T>(selector);
        if (!element) throw new Error(`Missing required element: ${selector}`);
        return element;
      }

      const cards = Array.from(document.querySelectorAll<HTMLElement>(".card"));
      const catalog = requiredElement<HTMLElement>("#catalog");
      const noResults = requiredElement<HTMLElement>("#noResults");
      const controls = {
        search: requiredElement<HTMLInputElement>("#search"),
        level: requiredElement<HTMLSelectElement>("#level"),
        sort: requiredElement<HTMLSelectElement>("#sort"),
        toggleDetails: requiredElement<HTMLButtonElement>("#toggleDetails")
      };

      function data(card: HTMLElement, key: string): string {
        return card.dataset[key] ?? "";
      }

      function matches(card: HTMLElement) {
        const query = controls.search.value.trim().toLowerCase();
        const level = controls.level.value;
        const haystack = [
          data(card, "search"),
          data(card, "name"),
          data(card, "description"),
          data(card, "author"),
          data(card, "github"),
          data(card, "language").toLowerCase(),
          data(card, "levels"),
          data(card, "useCases")
        ].join(" ");

        return (
          (!query || haystack.includes(query)) &&
          (!level || data(card, "levels").split(",").includes(level))
        );
      }

      function sortCards(visibleCards: HTMLElement[]) {
        const mode = controls.sort.value;
        return visibleCards.sort((a, b) => {
          if (mode === "name") return data(a, "name").localeCompare(data(b, "name"));
          if (mode === "updated") return data(b, "updated").localeCompare(data(a, "updated"));
          return Number(data(b, "stars")) - Number(data(a, "stars"));
        });
      }

      function render() {
        const visible = sortCards(cards.filter(matches));
        cards.forEach((card) => {
          card.hidden = !visible.includes(card);
        });
        visible.forEach((card) => catalog.appendChild(card));
        noResults.hidden = cards.length === 0 || visible.length > 0;
      }

      function syncCardExpandButton(card: HTMLElement) {
        const button = card.querySelector<HTMLButtonElement>(".detailReveal");
        if (!button) return;

        const title = card.querySelector("h2")?.textContent?.trim() || "此工具";
        const isExpanded = card.classList.contains("is-expanded");
        button.setAttribute("aria-expanded", String(isExpanded));
        button.setAttribute("aria-label", `${isExpanded ? "收合" : "展開"} ${title} 的細節`);
        button.title = isExpanded ? "收合細節" : "展開細節";
      }

      function setCompactMode(isCompact: boolean) {
        cards.forEach((card) => {
          card.classList.toggle("is-compact", isCompact);
          card.classList.remove("is-expanded");
          syncCardExpandButton(card);
        });

        controls.toggleDetails.textContent = isCompact ? "展開細節" : "隱藏細節";
        controls.toggleDetails.setAttribute("aria-pressed", String(isCompact));
      }

      controls.search.addEventListener("input", render);
      controls.level.addEventListener("change", render);
      controls.sort.addEventListener("change", render);
      controls.toggleDetails.addEventListener("click", () => {
        const isCompact = !cards.every((card) => card.classList.contains("is-compact"));
        setCompactMode(isCompact);
      });
      cards.forEach((card) => {
        card.querySelector(".detailReveal")?.addEventListener("click", () => {
          card.classList.toggle("is-expanded");
          syncCardExpandButton(card);
        });
        syncCardExpandButton(card);
      });
      setCompactMode(true);
      render();
    </script>
  </body>
</html>
